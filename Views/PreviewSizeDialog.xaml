<mah:MetroWindow x:Class="ImageFolderManager.Views.PreviewSizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="Preview Size Settings"
        Height="280"
        Width="350"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MahApps.Brushes.Control.Background}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="Adjust the size of image previews. Changing the size will clear the thumbnail cache."
                   TextWrapping="Wrap" Margin="0,0,0,20" Foreground="White"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Width:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
        <mah:NumericUpDown Grid.Row="1" Grid.Column="1" x:Name="WidthUpDown" Minimum="100" Maximum="500" Interval="10" Value="200"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Height:" VerticalAlignment="Center" Margin="0,10,10,0" Foreground="White"/>
        <mah:NumericUpDown Grid.Row="2" Grid.Column="1" x:Name="HeightUpDown" Margin="0,10,0,0" Minimum="100" Maximum="500" Interval="10" Value="300"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" 
                   Text="Note: Clearing cache will regenerate thumbnails the next time images are loaded."
                   TextWrapping="Wrap" Margin="0,20,0,0" Foreground="#AAAAAA" FontSize="11"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Apply" Width="80" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>